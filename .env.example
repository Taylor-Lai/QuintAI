APP_ENV=development
SECRET_KEY=replace-with-a-random-value-of-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=180

# Optional one-time administrator bootstrap. Leave all three blank to disable.
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
STATIC_DIR=static
DATABASE_URL=sqlite:///./doc_system.db

LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Optional table-engine performance and safety limits.
LLM_TIMEOUT_SECONDS=90
LLM_MAX_RETRIES=2
LLM_CONCURRENCY=3
LLM_CACHE_SIZE=128
LLM_MAX_CALLS_PER_RUN=40
LLM_MAX_TOTAL_TOKENS_PER_RUN=120000
TABLE_REPAIR_MAX_ATTEMPTS=1

# 上传、任务和限流
MAX_UPLOAD_BYTES=26214400
MAX_UPLOAD_FILES=10
MAX_ARCHIVE_ENTRIES=2000
MAX_ARCHIVE_UNCOMPRESSED_BYTES=104857600
TASK_TIMEOUT_SECONDS=900
TASK_MAX_ATTEMPTS=2
WORKER_CONCURRENCY=2
RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT=10
AI_RATE_LIMIT=6
# Docker 数据库密码（生产部署必须替换）
POSTGRES_PASSWORD=
