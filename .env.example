APP_ENV=development
SECRET_KEY=replace-with-a-random-value-of-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=180

# Optional one-time administrator bootstrap. Leave all three blank to disable.
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
STATIC_DIR=static
DATABASE_URL=sqlite:///./doc_system.db

LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Optional table-engine performance and safety limits.
LLM_TIMEOUT_SECONDS=90
LLM_MAX_RETRIES=2
LLM_CONCURRENCY=3
LLM_CACHE_SIZE=128
LLM_MAX_CALLS_PER_RUN=40
LLM_MAX_TOTAL_TOKENS_PER_RUN=120000
TABLE_REPAIR_MAX_ATTEMPTS=1
